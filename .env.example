# Copy this file to .env and fill in your values.

# Public domain for the packbase instance (Caddy obtains a Let's Encrypt cert automatically)
PACKBASE_DOMAIN=packages.example.com

# Public list of packages (optional, defaults to https://zub.javanile.org/packbase.json)
PACKBASE_SOURCE=https://zub.javanile.org/packbase.json

# Bearer token required for POST /api/fetch — use a strong random secret
PACKBASE_TOKEN=change-me-to-a-strong-secret
